      \            \n        b_layout.addLayout(meta)\n        self.chat_layout.addWidget(row)\n\
      \        QtCore.QTimer.singleShot(10, lambda: self.scroll_area.verticalScrollBar().setValue(self.scroll_area.verticalScrollBar().maximum()))\n"
