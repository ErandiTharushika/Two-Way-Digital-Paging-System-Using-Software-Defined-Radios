      \ self.chat_layout.takeAt(1)\n            if item.widget(): item.widget().deleteLater()\n\
      \        \n        msgs = self.history.get(chat_id, [])\n        for m in msgs:\n\
      \            self.add_bubble(m['text'], m['is_sender'], m['time'], m['status'])\n\
