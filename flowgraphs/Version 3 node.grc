      \n        # Sidebar\n        sidebar = QtWidgets.QWidget()\n        sidebar.setFixedWidth(280)\n\
      \        sidebar.setStyleSheet(\"background-color: #111b21; color: #e9edef;\
      \ border-right: 1px solid #333;\")\n        sidebar_layout = QtWidgets.QVBoxLayout(sidebar)\n\
